# === Chat LLM (pick one) ===
# LLM_PROVIDER=openai | groq | gemini | ollama

# A) OpenAI (paid)
LLM_PROVIDER=groq
GROQ_API_KEY=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

# B) Groq — free key: https://console.groq.com/  (comment out A, uncomment below)
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# OPENAI_API_KEY=

# C) Gemini — free key: https://aistudio.google.com/apikey
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# D) Ollama — local, no key: https://ollama.com/
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=

# Optional: override model (defaults: gpt-4o-mini, llama-3.3-70b-versatile, gemini-2.0-flash, llama3.2)
# CHAT_MODEL=

# === Embeddings (vector DB + dedup) ===
# auto = OpenAI if OPENAI_API_KEY is set, else local Hugging Face (free, no key)
EMBEDDING_PROVIDER=auto
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Web search
TAVILY_API_KEY=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
# SERPER_API_KEY=

VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./data/chroma
FAISS_INDEX_DIR=./data/faiss

SEARCH_MAX_RESULTS=8
SCRAPE_MAX_URLS=12
DEDUP_SIMILARITY_THRESHOLD=0.88
ENABLE_MULTI_HOP=false
ENABLE_CACHE=true
ENABLE_ASYNC_SCRAPE=false
LOG_LEVEL=INFO

REPORTS_DIR=./data/reports
CACHE_DIR=./data/cache
